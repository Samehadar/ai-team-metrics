# Optional: external activity provider for per-developer activity heatmap.
# Leave empty to disable — the app works fully without it.
#
# Either point to a same-origin reverse-proxied path (recommended for browsers):
VITE_ACTIVITY_API_BASE=/activity-api
# Or a full URL (CORS must be allowed by the upstream):
# VITE_ACTIVITY_API_BASE=https://your.provider.example.com
#
# Optional: where the dev-server proxy at VITE_ACTIVITY_API_BASE forwards to.
# VITE_ACTIVITY_PROXY_TARGET=https://your.provider.example.com
# VITE_ACTIVITY_PROXY_PATH=/activity-api
#
# Optional: default external user id (rarely needed; per-member ids are preferred).
VITE_ACTIVITY_DEFAULT_USER_ID=
#
# Basic auth for the upstream provider:
VITE_ACTIVITY_BASIC_AUTH_USER=
VITE_ACTIVITY_BASIC_AUTH_PASSWORD=
